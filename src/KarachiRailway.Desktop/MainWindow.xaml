<Window x:Class="KarachiRailway.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:KarachiRailway.Desktop.ViewModels"
        mc:Ignorable="d"
        Title="Karachi Railway System — Simulation"
        Height="820" Width="1280"
        MinHeight="700" MinWidth="1100"
        Background="{StaticResource BackgroundDeepBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Title bar -->
            <RowDefinition Height="64"/>
            <!-- Content -->
            <RowDefinition Height="*"/>
            <!-- Status bar -->
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════
             TITLE BAR
             ══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource BackgroundCardBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Icon + Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="36" Height="36" CornerRadius="8"
                            Background="{StaticResource AccentBlueBrush}"
                            Margin="0,0,12,0">
                        <TextBlock Text="🚂" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Karachi Railway System" Style="{StaticResource HeadingMedium}"/>
                        <TextBlock Text="M/M/1 Queue Simulation" Style="{StaticResource KpiLabel}" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Status badge -->
                <Border Grid.Column="2" CornerRadius="20" Padding="16,6" VerticalAlignment="Center"
                        Background="{Binding StatusColor, Converter={StaticResource HexToBrush}, ConverterParameter='20'}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center"
                                 Fill="{Binding StatusColor, Converter={StaticResource HexToBrush}}"/>
                        <TextBlock Text="{Binding StatusLabel}"
                                   FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{Binding StatusColor, Converter={StaticResource HexToBrush}}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════
             MAIN CONTENT  (3 columns)
             ══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <!-- Left panel: settings -->
                <ColumnDefinition Width="300"/>
                <!-- Right panels: KPIs + log -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT: SETTINGS PANEL ─────────────────────────────────── -->
            <Border Grid.Column="0"
                    Background="{StaticResource BackgroundCardBrush}"
                    CornerRadius="12"
                    Margin="0,0,12,0"
                    Padding="20">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                        <TextBlock Text="SIMULATION SETTINGS" Style="{StaticResource HeadingSmall}" Margin="0,0,0,16"/>

                        <!-- M/M/1 Parameters -->
                        <TextBlock Text="Queue Model" Style="{StaticResource HeadingMedium}" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Arrival Rate λ (passengers/min)"
                                       Style="{StaticResource ParamLabel}" TextWrapping="Wrap"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ArrivalRate, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ParamTextBox}"
                                     IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolToVisibility}}"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Service Rate μ (passengers/min)"
                                       Style="{StaticResource ParamLabel}" TextWrapping="Wrap"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ServiceRate, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ParamTextBox}"
                                     IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolToVisibility}}"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Duration (minutes)"
                                       Style="{StaticResource ParamLabel}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding DurationMinutes, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ParamTextBox}"
                                     IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolToVisibility}}"/>
                        </Grid>

                        <!-- Stability hint -->
                        <Border CornerRadius="6" Padding="10,8" Margin="0,4,0,16"
                                Background="#0F172A">
                            <TextBlock Text="{Binding StabilityHint}"
                                       FontFamily="Segoe UI" FontSize="12"
                                       Foreground="{Binding KpiRho, Converter={StaticResource UtilToBrush}}"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <Separator Style="{StaticResource HSep}"/>

                        <!-- Flow Probabilities -->
                        <TextBlock Text="Flow Probabilities" Style="{StaticResource HeadingMedium}" Margin="0,8,0,12"/>

                        <!-- Helper template for probability rows -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Ticket Required"
                                       Style="{StaticResource ParamLabel}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding TicketRequiredProb, StringFormat=F2, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ParamTextBox}"
                                     IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolToVisibility}}"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Buy Ticket (Inquiry)"
                                       Style="{StaticResource ParamLabel}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding BuyTicketProb, StringFormat=F2, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ParamTextBox}"
                                     IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolToVisibility}}"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Use Card (vs Cash)"
                                       Style="{StaticResource ParamLabel}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding CardUsageProb, StringFormat=F2, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ParamTextBox}"
                                     IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolToVisibility}}"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Card Valid"
                                       Style="{StaticResource ParamLabel}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding CardValidProb, StringFormat=F2, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ParamTextBox}"
                                     IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolToVisibility}}"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Account Valid"
                                       Style="{StaticResource ParamLabel}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding AccountValidProb, StringFormat=F2, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ParamTextBox}"
                                     IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolToVisibility}}"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Sufficient Funds"
                                       Style="{StaticResource ParamLabel}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding SufficientFundsProb, StringFormat=F2, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ParamTextBox}"
                                     IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolToVisibility}}"/>
                        </Grid>

                        <!-- Trace mode toggle -->
                        <CheckBox Style="{StaticResource ToggleCheck}"
                                  IsChecked="{Binding TraceModeEnabled}"
                                  Content="Show step trace per passenger"
                                  Margin="0,0,0,16"
                                  IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolToVisibility}}"/>

                        <!-- Validation error -->
                        <Border CornerRadius="6" Padding="10,8"
                                Background="#2D1B1B"
                                Visibility="{Binding HasValidationError, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding ValidationError}"
                                       FontFamily="Segoe UI" FontSize="12"
                                       Foreground="{StaticResource AccentRedBrush}"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <Separator Style="{StaticResource HSep}"/>

                        <!-- Control Buttons -->
                        <TextBlock Text="CONTROLS" Style="{StaticResource HeadingSmall}" Margin="0,8,0,12"/>

                        <WrapPanel>
                            <Button Content="▶  Start"
                                    Style="{StaticResource ButtonStart}"
                                    Command="{Binding StartCommand}"
                                    Margin="0,0,8,8"/>
                            <Button Content="⏸  Pause"
                                    Style="{StaticResource ButtonPause}"
                                    Command="{Binding PauseCommand}"
                                    Margin="0,0,8,8"/>
                            <Button Content="▶  Resume"
                                    Style="{StaticResource ButtonResume}"
                                    Command="{Binding ResumeCommand}"
                                    Margin="0,0,8,8"/>
                            <Button Content="⏹  Stop"
                                    Style="{StaticResource ButtonStop}"
                                    Command="{Binding StopCommand}"
                                    Margin="0,0,8,8"/>
                            <Button Content="↺  Reset"
                                    Style="{StaticResource ButtonReset}"
                                    Command="{Binding ResetCommand}"
                                    Margin="0,0,0,8"/>
                        </WrapPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ── RIGHT: KPIs + LOG + SUMMARY ─────────────────────────── -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Progress bar -->
                    <RowDefinition Height="Auto"/>
                    <!-- KPI Cards row 1 -->
                    <RowDefinition Height="Auto"/>
                    <!-- KPI Cards row 2 -->
                    <RowDefinition Height="*"/>
                    <!-- Log + Summary -->
                </Grid.RowDefinitions>

                <!-- Live progress -->
                <Border Grid.Row="0"
                        Background="{StaticResource BackgroundCardBrush}"
                        CornerRadius="10" Margin="0,0,0,10" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="SIMULATION PROGRESS" Style="{StaticResource HeadingSmall}" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Passengers processed: " Style="{StaticResource BodyText}"/>
                                <TextBlock Text="{Binding ProcessedCount}" FontFamily="Segoe UI" FontSize="13"
                                           FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="   |   Sim time: " Style="{StaticResource BodyText}"/>
                                <TextBlock Text="{Binding SimCurrentTime, StringFormat={}{0:F1} min}"
                                           FontFamily="Segoe UI" FontSize="13"
                                           FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Completed: " Style="{StaticResource BodyText}"/>
                            <TextBlock Text="{Binding TotalCompleted}"
                                       FontFamily="Segoe UI" FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource AccentGreenBrush}" Margin="0,0,12,0"/>
                            <TextBlock Text="Left: " Style="{StaticResource BodyText}"/>
                            <TextBlock Text="{Binding TotalLeft}"
                                       FontFamily="Segoe UI" FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource AccentRedBrush}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- KPI Cards Row 1 -->
                <UniformGrid Grid.Row="1" Rows="1" Columns="5" Margin="0,0,0,10">

                    <!-- Utilisation -->
                    <Border Margin="0,0,8,0" Background="{StaticResource BackgroundCardBrush}"
                            CornerRadius="10" Padding="16,14">
                        <StackPanel>
                            <TextBlock Text="UTILISATION (ρ)" Style="{StaticResource HeadingSmall}" Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding KpiRho, Converter={StaticResource DoubleToPercent}}"
                                       Style="{StaticResource KpiValue}"
                                       Foreground="{Binding KpiRho, Converter={StaticResource UtilToBrush}}"/>
                            <TextBlock Text="Server busy fraction" Style="{StaticResource KpiLabel}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Avg Wait Wq -->
                    <Border Margin="0,0,8,0" Background="{StaticResource BackgroundCardBrush}"
                            CornerRadius="10" Padding="16,14">
                        <StackPanel>
                            <TextBlock Text="AVG WAIT Wq" Style="{StaticResource HeadingSmall}" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                <TextBlock Text="{Binding KpiWq, Converter={StaticResource DoubleToFixed}}"
                                           Style="{StaticResource KpiValue}"/>
                                <TextBlock Text=" min" FontFamily="Segoe UI" FontSize="14"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Bottom" Margin="2,0,0,4"/>
                            </StackPanel>
                            <TextBlock Text="In queue (theory)" Style="{StaticResource KpiLabel}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Avg System Time W -->
                    <Border Margin="0,0,8,0" Background="{StaticResource BackgroundCardBrush}"
                            CornerRadius="10" Padding="16,14">
                        <StackPanel>
                            <TextBlock Text="AVG TIME W" Style="{StaticResource HeadingSmall}" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                <TextBlock Text="{Binding KpiW, Converter={StaticResource DoubleToFixed}}"
                                           Style="{StaticResource KpiValue}"/>
                                <TextBlock Text=" min" FontFamily="Segoe UI" FontSize="14"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Bottom" Margin="2,0,0,4"/>
                            </StackPanel>
                            <TextBlock Text="In system (theory)" Style="{StaticResource KpiLabel}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Queue Length Lq -->
                    <Border Margin="0,0,8,0" Background="{StaticResource BackgroundCardBrush}"
                            CornerRadius="10" Padding="16,14">
                        <StackPanel>
                            <TextBlock Text="QUEUE LENGTH Lq" Style="{StaticResource HeadingSmall}" Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding KpiLq, Converter={StaticResource DoubleToFixed}}"
                                       Style="{StaticResource KpiValue}"/>
                            <TextBlock Text="Avg in queue (theory)" Style="{StaticResource KpiLabel}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- System Length L -->
                    <Border Background="{StaticResource BackgroundCardBrush}"
                            CornerRadius="10" Padding="16,14">
                        <StackPanel>
                            <TextBlock Text="SYSTEM LENGTH L" Style="{StaticResource HeadingSmall}" Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding KpiL, Converter={StaticResource DoubleToFixed}}"
                                       Style="{StaticResource KpiValue}"/>
                            <TextBlock Text="Avg in system (theory)" Style="{StaticResource KpiLabel}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- KPI Cards Row 2 (simulation-measured) -->
                <UniformGrid Grid.Row="2" Rows="1" Columns="4" Margin="0,0,0,10">

                    <Border Margin="0,0,8,0" Background="{StaticResource BackgroundPanelBrush}"
                            CornerRadius="10" Padding="14,12">
                        <StackPanel>
                            <TextBlock Text="SIM AVG WAIT" Style="{StaticResource HeadingSmall}" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                <TextBlock Text="{Binding SimAvgWait, Converter={StaticResource DoubleToFixed}}"
                                           FontFamily="Segoe UI" FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text=" min" FontFamily="Segoe UI" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Bottom" Margin="2,0,0,3"/>
                            </StackPanel>
                            <TextBlock Text="Measured from simulation" Style="{StaticResource KpiLabel}" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,8,0" Background="{StaticResource BackgroundPanelBrush}"
                            CornerRadius="10" Padding="14,12">
                        <StackPanel>
                            <TextBlock Text="SIM AVG SYSTEM TIME" Style="{StaticResource HeadingSmall}" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                <TextBlock Text="{Binding SimAvgSys, Converter={StaticResource DoubleToFixed}}"
                                           FontFamily="Segoe UI" FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text=" min" FontFamily="Segoe UI" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Bottom" Margin="2,0,0,3"/>
                            </StackPanel>
                            <TextBlock Text="Measured from simulation" Style="{StaticResource KpiLabel}" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,8,0" Background="{StaticResource BackgroundPanelBrush}"
                            CornerRadius="10" Padding="14,12">
                        <StackPanel>
                            <TextBlock Text="THROUGHPUT" Style="{StaticResource HeadingSmall}" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                <TextBlock Text="{Binding Throughput, Converter={StaticResource DoubleToFixed}}"
                                           FontFamily="Segoe UI" FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource AccentGreenBrush}"/>
                                <TextBlock Text=" /min" FontFamily="Segoe UI" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Bottom" Margin="2,0,0,3"/>
                            </StackPanel>
                            <TextBlock Text="Completed passengers/min" Style="{StaticResource KpiLabel}" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource BackgroundPanelBrush}"
                            CornerRadius="10" Padding="14,12">
                        <StackPanel>
                            <TextBlock Text="SUCCESS RATE" Style="{StaticResource HeadingSmall}" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                <TextBlock Text="{Binding CompletionRate, StringFormat={}{0:F1}}"
                                           FontFamily="Segoe UI" FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBlueBrush}"/>
                                <TextBlock Text="%" FontFamily="Segoe UI" FontSize="14"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Bottom" Margin="1,0,0,3"/>
                            </StackPanel>
                            <TextBlock Text="Boarded vs arrived" Style="{StaticResource KpiLabel}" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                </UniformGrid>

                <!-- Bottom row: Log + Summary -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="340"/>
                    </Grid.ColumnDefinitions>

                    <!-- Passenger Log -->
                    <Border Grid.Column="0" Margin="0,0,10,0"
                            Background="{StaticResource BackgroundCardBrush}"
                            CornerRadius="10" Padding="16">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="PASSENGER LOG"
                                       Style="{StaticResource HeadingSmall}" Margin="0,0,0,10"/>
                            <ListBox ItemsSource="{Binding PassengerLog}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     FontFamily="Consolas"
                                     FontSize="11"
                                     Foreground="{StaticResource TextSecondaryBrush}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                     VirtualizingPanel.IsVirtualizing="True"/>
                        </DockPanel>
                    </Border>

                    <!-- Plain-language Summary + Trace -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Summary -->
                        <Border Grid.Row="0"
                                Background="{StaticResource BackgroundCardBrush}"
                                CornerRadius="10" Padding="16" Margin="0,0,0,10">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="PLAIN-LANGUAGE SUMMARY"
                                           Style="{StaticResource HeadingSmall}" Margin="0,0,0,10"/>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBlock Text="{Binding PlainSummary}"
                                               FontFamily="Segoe UI" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" LineHeight="20"/>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>

                        <!-- Trace Output (shown only if trace mode enabled) -->
                        <Border Grid.Row="1"
                                Background="{StaticResource BackgroundCardBrush}"
                                CornerRadius="10" Padding="16"
                                Visibility="{Binding TraceModeEnabled, Converter={StaticResource BoolToVisibility}}">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="TRACE MODE — PASSENGER #1"
                                           Style="{StaticResource HeadingSmall}" Margin="0,0,0,10"/>
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="100">
                                    <TextBlock Text="{Binding TraceOutput}"
                                               FontFamily="Consolas" FontSize="11"
                                               Foreground="{StaticResource AccentBlueBrush}"
                                               TextWrapping="Wrap"/>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════════════════════
             STATUS BAR
             ══════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{StaticResource BackgroundCardBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Karachi Railway System · M/M/1 Single-Server Queue Simulation · .NET 8 WPF"
                           FontFamily="Segoe UI" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding TotalArrived, StringFormat='Total arrivals: {0}'}"
                           FontFamily="Segoe UI" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>


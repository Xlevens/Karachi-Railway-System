<Window x:Class="KarachiRailway.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:KarachiRailway.Desktop.ViewModels"
        mc:Ignorable="d"
        Title="Karachi Railway System — Simulation"
        Height="900" Width="1400"
        MinHeight="700" MinWidth="1200"
        Background="{StaticResource BackgroundDeepBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>

        <!-- ══ TITLE BAR ══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource BackgroundCardBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="36" Height="36" CornerRadius="8"
                            Background="{StaticResource AccentBlueBrush}" Margin="0,0,12,0">
                        <TextBlock Text="🚂" FontSize="18"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Karachi Railway System" Style="{StaticResource HeadingMedium}"/>
                        <TextBlock Text="M/M/1 Queue Simulation — Flow Diagram Mode"
                                   Style="{StaticResource KpiLabel}" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
                <Border Grid.Column="2" CornerRadius="20" Padding="16,6" VerticalAlignment="Center"
                        Background="{Binding StatusColor, Converter={StaticResource HexToBrush}, ConverterParameter=20}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center"
                                 Fill="{Binding StatusColor, Converter={StaticResource HexToBrush}}"/>
                        <TextBlock Text="{Binding StatusLabel}" FontFamily="Segoe UI"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{Binding StatusColor, Converter={StaticResource HexToBrush}}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ══ MAIN CONTENT ═══════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT: SETTINGS PANEL ────────────────────────────────────── -->
            <Border Grid.Column="0"
                    Background="{StaticResource BackgroundCardBrush}"
                    CornerRadius="12" Margin="0,0,10,0" Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="SIMULATION SETTINGS"
                                   Style="{StaticResource HeadingSmall}" Margin="0,0,0,14"/>

                        <TextBlock Text="Queue Model" Style="{StaticResource HeadingMedium}" Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Arrival Rate λ (pax/min)"
                                       Style="{StaticResource ParamLabel}" TextWrapping="Wrap"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ArrivalRate, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ParamTextBox}"
                                     IsEnabled="{Binding CanEditParams}"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Service Rate μ (pax/min)"
                                       Style="{StaticResource ParamLabel}" TextWrapping="Wrap"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ServiceRate, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ParamTextBox}"
                                     IsEnabled="{Binding CanEditParams}"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Duration (minutes)"
                                       Style="{StaticResource ParamLabel}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding DurationMinutes, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ParamTextBox}"
                                     IsEnabled="{Binding CanEditParams}"/>
                        </Grid>

                        <Border CornerRadius="6" Padding="8,6" Margin="0,4,0,14"
                                Background="#0F172A">
                            <TextBlock Text="{Binding StabilityHint}" FontFamily="Segoe UI"
                                       FontSize="11"
                                       Foreground="{Binding KpiRho, Converter={StaticResource UtilToBrush}}"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <Separator Style="{StaticResource HSep}"/>
                        <TextBlock Text="Flow Probabilities"
                                   Style="{StaticResource HeadingMedium}" Margin="0,6,0,10"/>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="90"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Ticket Required" Style="{StaticResource ParamLabel}"/>
                            <TextBox Grid.Column="1" Text="{Binding TicketRequiredProb, StringFormat=F2, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ParamTextBox}" IsEnabled="{Binding CanEditParams}"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="90"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Buy Ticket (Inquiry)" Style="{StaticResource ParamLabel}"/>
                            <TextBox Grid.Column="1" Text="{Binding BuyTicketProb, StringFormat=F2, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ParamTextBox}" IsEnabled="{Binding CanEditParams}"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="90"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Use Card (vs Cash)" Style="{StaticResource ParamLabel}"/>
                            <TextBox Grid.Column="1" Text="{Binding CardUsageProb, StringFormat=F2, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ParamTextBox}" IsEnabled="{Binding CanEditParams}"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="90"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Card Valid" Style="{StaticResource ParamLabel}"/>
                            <TextBox Grid.Column="1" Text="{Binding CardValidProb, StringFormat=F2, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ParamTextBox}" IsEnabled="{Binding CanEditParams}"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="90"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Account Valid" Style="{StaticResource ParamLabel}"/>
                            <TextBox Grid.Column="1" Text="{Binding AccountValidProb, StringFormat=F2, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ParamTextBox}" IsEnabled="{Binding CanEditParams}"/>
                        </Grid>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="90"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Sufficient Funds" Style="{StaticResource ParamLabel}"/>
                            <TextBox Grid.Column="1" Text="{Binding SufficientFundsProb, StringFormat=F2, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ParamTextBox}" IsEnabled="{Binding CanEditParams}"/>
                        </Grid>

                        <CheckBox Style="{StaticResource ToggleCheck}"
                                  IsChecked="{Binding TraceModeEnabled}"
                                  Content="Show step trace (first 50)"
                                  Margin="0,0,0,12"
                                  IsEnabled="{Binding CanEditParams}"/>

                        <Border CornerRadius="6" Padding="8,6" Margin="0,0,0,10"
                                Background="#2D1B1B"
                                Visibility="{Binding HasValidationError, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding ValidationError}" FontFamily="Segoe UI"
                                       FontSize="11" Foreground="{StaticResource AccentRedBrush}"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <Separator Style="{StaticResource HSep}"/>
                        <TextBlock Text="CONTROLS" Style="{StaticResource HeadingSmall}" Margin="0,6,0,10"/>

                        <WrapPanel>
                            <Button Content="▶  Simulate" Style="{StaticResource ButtonStart}"
                                    Command="{Binding StartCommand}" Margin="0,0,6,6"/>
                            <Button Content="⏸  Pause"   Style="{StaticResource ButtonPause}"
                                    Command="{Binding PauseCommand}" Margin="0,0,6,6"/>
                            <Button Content="▶  Resume"  Style="{StaticResource ButtonResume}"
                                    Command="{Binding ResumeCommand}" Margin="0,0,6,6"/>
                            <Button Content="⏹  Stop"    Style="{StaticResource ButtonStop}"
                                    Command="{Binding StopCommand}" Margin="0,0,6,6"/>
                            <Button Content="↺  Reset"   Style="{StaticResource ButtonReset}"
                                    Command="{Binding ResetCommand}" Margin="0,0,0,6"/>
                        </WrapPanel>

                        <Separator Style="{StaticResource HSep}"/>
                        <TextBlock Text="PLAYBACK SPEED" Style="{StaticResource HeadingSmall}" Margin="0,6,0,8"/>
                        <ComboBox ItemsSource="{Binding SpeedOptions}"
                                  SelectedItem="{Binding SelectedSpeed}"
                                  Style="{StaticResource SpeedComboBox}"
                                  HorizontalAlignment="Left"/>

                        <!-- Trace log -->
                        <Separator Style="{StaticResource HSep}"/>
                        <TextBlock Text="STEP TRACE" Style="{StaticResource HeadingSmall}" Margin="0,6,0,6"/>
                        <Border Height="120" Background="#0F172A" CornerRadius="6" Padding="6"
                                Visibility="{Binding TraceModeEnabled, Converter={StaticResource BoolToVisibility}}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding PassengerLog}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontSize="9"
                                                       FontFamily="Consolas"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" Margin="0,1"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ── CENTER: FLOW DIAGRAM ─────────────────────────────────────── -->
            <Border Grid.Column="1"
                    Background="{StaticResource BackgroundCardBrush}"
                    CornerRadius="12" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Progress / info bar -->
                    <Border Grid.Row="0" Padding="14,10"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="FLOW DIAGRAM" Style="{StaticResource HeadingSmall}" Margin="0,0,0,4"/>
                                <ProgressBar Value="{Binding PlaybackProgress}"
                                             Maximum="{Binding PlaybackTotal}"
                                             Height="4" Width="300"
                                             HorizontalAlignment="Left"
                                             Foreground="{StaticResource AccentBlueBrush}"
                                             Background="#334155"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Sim time: " Style="{StaticResource KpiLabel}"/>
                                <TextBlock Text="{Binding SimCurrentTime, StringFormat=F1}"
                                           FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text=" min" Style="{StaticResource KpiLabel}" Margin="0,0,16,0"/>
                                <TextBlock Text="Arrived: " Style="{StaticResource KpiLabel}"/>
                                <TextBlock Text="{Binding TotalArrived}"
                                           FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBlueBrush}" Margin="0,0,12,0"/>
                                <TextBlock Text="Served: " Style="{StaticResource KpiLabel}"/>
                                <TextBlock Text="{Binding TotalCompleted}"
                                           FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentGreenBrush}" Margin="0,0,12,0"/>
                                <TextBlock Text="Left: " Style="{StaticResource KpiLabel}"/>
                                <TextBlock Text="{Binding TotalLeft}"
                                           FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentRedBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Scrollable flow canvas -->
                    <ScrollViewer Grid.Row="1"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="Transparent">
                        <Canvas Width="1080" Height="1185" ClipToBounds="False">

                            <!-- ── EDGES ─────────────────────────────────────── -->
                            <ItemsControl ItemsSource="{Binding FlowEdges}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas Width="1080" Height="1185"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Canvas Width="1" Height="1" ClipToBounds="False">
                                            <Polyline Points="{Binding Points}"
                                                      Stroke="#475569" StrokeThickness="1.5"
                                                      StrokeDashArray="0"/>
                                            <Polygon Points="{Binding ArrowheadPoints}"
                                                     Fill="#475569" Stroke="#475569"
                                                     StrokeThickness="1"/>
                                            <TextBlock Canvas.Left="{Binding LabelLeft}"
                                                       Canvas.Top="{Binding LabelTop}"
                                                       Text="{Binding Label}"
                                                       Visibility="{Binding HasLabel, Converter={StaticResource BoolToVisibility}}"
                                                       FontFamily="Segoe UI" FontSize="9"
                                                       FontWeight="SemiBold"
                                                       Foreground="#94A3B8"
                                                       Background="{StaticResource BackgroundCardBrush}"
                                                       Padding="2,1"/>
                                        </Canvas>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- ── NODES ─────────────────────────────────────── -->
                            <ItemsControl ItemsSource="{Binding FlowNodes}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas Width="1080" Height="1185"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                                        <Setter Property="Canvas.Top"  Value="{Binding Top}"/>
                                        <Setter Property="Width"       Value="{Binding Width}"/>
                                        <Setter Property="Height"      Value="{Binding Height}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Width="{Binding Width}" Height="{Binding Height}"
                                              ToolTip="{Binding Title}">
                                            <!-- Diamond for decision nodes -->
                                            <Polygon Points="{Binding DiamondPoints}"
                                                     Fill="{Binding CurrentBackground,  Converter={StaticResource HexToBrush}}"
                                                     Stroke="{Binding CurrentBorderColor, Converter={StaticResource HexToBrush}}"
                                                     StrokeThickness="1.5"
                                                     Visibility="{Binding IsDecision, Converter={StaticResource BoolToVisibility}}"/>

                                            <!-- Rectangle for non-decision nodes -->
                                            <Border Background="{Binding CurrentBackground,  Converter={StaticResource HexToBrush}}"
                                                    BorderBrush="{Binding CurrentBorderColor, Converter={StaticResource HexToBrush}}"
                                                    BorderThickness="1.5"
                                                    CornerRadius="{Binding CornerRadius}"
                                                    Visibility="{Binding IsNotDecision, Converter={StaticResource BoolToVisibility}}"/>

                                            <!-- Node title -->
                                            <TextBlock Text="{Binding Title}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontFamily="Segoe UI" FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="White"
                                                       TextWrapping="Wrap"
                                                       TextAlignment="Center"
                                                       Margin="6,2" MaxWidth="{Binding Width}"/>

                                            <!-- Active passenger count badge -->
                                            <Border Width="18" Height="18" CornerRadius="9"
                                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                                    Margin="0,-5,-5,0"
                                                    Background="#F59E0B"
                                                    Visibility="{Binding HasActivePassengers, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="{Binding ActiveCountLabel}"
                                                           FontSize="9" FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="White"/>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- ── PASSENGER TOKENS ───────────────────────────── -->
                            <ItemsControl ItemsSource="{Binding PassengerTokens}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas Width="1080" Height="1185"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                        <Setter Property="Canvas.Top"  Value="{Binding Y}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Width="18" Height="18" ToolTip="{Binding Label}">
                                            <Ellipse Fill="{Binding TokenColor, Converter={StaticResource HexToBrush}}"
                                                     Stroke="White" StrokeThickness="0.8"
                                                     Opacity="0.92"/>
                                            <TextBlock Text="{Binding Label}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontFamily="Segoe UI" FontSize="7"
                                                       FontWeight="Bold" Foreground="White"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </Canvas>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ── RIGHT: KPI PANEL ─────────────────────────────────────────── -->
            <Border Grid.Column="2"
                    Background="{StaticResource BackgroundCardBrush}"
                    CornerRadius="12" Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="LIVE METRICS" Style="{StaticResource HeadingSmall}" Margin="0,0,0,14"/>

                        <!-- Served / Left / Arrived counters -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="8" Padding="8,10" Margin="0,0,4,0"
                                    Background="#0F2A18">
                                <StackPanel>
                                    <TextBlock Text="{Binding TotalCompleted}" Style="{StaticResource KpiValue}"
                                               FontSize="22" Foreground="{StaticResource AccentGreenBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Served" Style="{StaticResource KpiLabel}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" CornerRadius="8" Padding="8,10" Margin="2,0"
                                    Background="#2D1010">
                                <StackPanel>
                                    <TextBlock Text="{Binding TotalLeft}" Style="{StaticResource KpiValue}"
                                               FontSize="22" Foreground="{StaticResource AccentRedBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Left" Style="{StaticResource KpiLabel}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" CornerRadius="8" Padding="8,10" Margin="4,0,0,0"
                                    Background="#1A2744">
                                <StackPanel>
                                    <TextBlock Text="{Binding TotalArrived}" Style="{StaticResource KpiValue}"
                                               FontSize="22" Foreground="{StaticResource AccentBlueBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Arrived" Style="{StaticResource KpiLabel}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Separator Style="{StaticResource HSep}"/>
                        <TextBlock Text="M/M/1 ANALYTICAL KPIs"
                                   Style="{StaticResource HeadingSmall}" Margin="0,4,0,10"/>

                        <!-- KPI rows -->
                        <Border CornerRadius="8" Padding="10,8" Margin="0,0,0,6"
                                Background="{StaticResource BackgroundPanelBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Utilisation (ρ)" Style="{StaticResource KpiLabel}"/>
                                    <TextBlock Text="Arrival / Service" FontFamily="Segoe UI"
                                               FontSize="9" Foreground="#475569"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding KpiRho, Converter={StaticResource DoubleToFixed}}"
                                           FontFamily="Segoe UI" FontSize="20" FontWeight="Bold"
                                           Foreground="{Binding KpiRho, Converter={StaticResource UtilToBrush}}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border CornerRadius="8" Padding="10,8" Margin="0,0,0,6"
                                Background="{StaticResource BackgroundPanelBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Avg Queue Wait (Wq)" Style="{StaticResource KpiLabel}"/>
                                    <TextBlock Text="minutes" FontFamily="Segoe UI" FontSize="9" Foreground="#475569"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding KpiWq, Converter={StaticResource DoubleToFixed}}"
                                           FontFamily="Segoe UI" FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border CornerRadius="8" Padding="10,8" Margin="0,0,0,6"
                                Background="{StaticResource BackgroundPanelBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Avg System Time (W)" Style="{StaticResource KpiLabel}"/>
                                    <TextBlock Text="minutes" FontFamily="Segoe UI" FontSize="9" Foreground="#475569"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding KpiW, Converter={StaticResource DoubleToFixed}}"
                                           FontFamily="Segoe UI" FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border CornerRadius="8" Padding="10,8" Margin="0,0,0,6"
                                Background="{StaticResource BackgroundPanelBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Avg Queue Length (Lq)" Style="{StaticResource KpiLabel}"/>
                                    <TextBlock Text="passengers" FontFamily="Segoe UI" FontSize="9" Foreground="#475569"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding KpiLq, Converter={StaticResource DoubleToFixed}}"
                                           FontFamily="Segoe UI" FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border CornerRadius="8" Padding="10,8" Margin="0,0,0,10"
                                Background="{StaticResource BackgroundPanelBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Avg in System (L)" Style="{StaticResource KpiLabel}"/>
                                    <TextBlock Text="passengers" FontFamily="Segoe UI" FontSize="9" Foreground="#475569"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding KpiL, Converter={StaticResource DoubleToFixed}}"
                                           FontFamily="Segoe UI" FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Separator Style="{StaticResource HSep}"/>
                        <TextBlock Text="SIMULATION RESULTS" Style="{StaticResource HeadingSmall}" Margin="0,4,0,8"/>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Avg Wait (simulated)" Style="{StaticResource KpiLabel}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding SimAvgWait, Converter={StaticResource DoubleToFixed}}"
                                       FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Avg System (simulated)" Style="{StaticResource KpiLabel}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding SimAvgSys, Converter={StaticResource DoubleToFixed}}"
                                       FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Throughput (pax/min)" Style="{StaticResource KpiLabel}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Throughput, Converter={StaticResource DoubleToFixed}}"
                                       FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentGreenBrush}"/>
                        </Grid>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Completion Rate" Style="{StaticResource KpiLabel}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding CompletionRate, StringFormat=F1}"
                                       FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentGreenBrush}"/>
                        </Grid>

                        <Separator Style="{StaticResource HSep}"/>
                        <Border CornerRadius="6" Padding="10,8" Margin="0,8,0,0"
                                Background="#0F172A">
                            <TextBlock Text="{Binding PlainSummary}" FontFamily="Segoe UI"
                                       FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ══ STATUS BAR ═════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{StaticResource BackgroundCardBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding PlainSummary}"
                           Style="{StaticResource KpiLabel}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="1"
                           Text="Karachi Railway System v2.0 — Flow Diagram Edition"
                           Style="{StaticResource KpiLabel}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>

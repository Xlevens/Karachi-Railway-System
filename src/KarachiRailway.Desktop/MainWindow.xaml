<Window x:Class="KarachiRailway.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:KarachiRailway.Desktop.ViewModels"
        mc:Ignorable="d"
        Title="Karachi Railway System — Simulation"
        Height="900" Width="1400"
        MinHeight="700" MinWidth="1200"
        Background="{StaticResource BackgroundDeepBrush}"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <!-- ══ WINDOW ENTRANCE FADE-IN ══════════════════════════════════════════ -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="RootGrid"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.55">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="RootGrid"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                     From="18" To="0" Duration="0:0:0.55">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid x:Name="RootGrid">
        <Grid.RenderTransform>
            <TranslateTransform Y="0"/>
        </Grid.RenderTransform>

        <Grid.RowDefinitions>
            <RowDefinition Height="68"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="34"/>
        </Grid.RowDefinitions>

        <!-- ══ TITLE BAR ══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource TitleBarGradient}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Border.Effect>
                <DropShadowEffect Color="#000000" ShadowDepth="2" BlurRadius="12" Opacity="0.5"/>
            </Border.Effect>
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,14,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1D4ED8" Offset="0"/>
                                <GradientStop Color="#3B82F6" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#3B82F6" ShadowDepth="0" BlurRadius="10" Opacity="0.6"/>
                        </Border.Effect>
                        <TextBlock Text="&#x1F682;" FontSize="20"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Karachi Railway System"
                                   Style="{StaticResource HeadingMedium}"
                                   FontSize="16"/>
                        <TextBlock Text="M/M/1 Queue Simulation  ·  Flow Diagram Mode"
                                   Style="{StaticResource KpiLabel}"
                                   Margin="0,2,0,0" Opacity="0.75"/>
                    </StackPanel>
                </StackPanel>

                <!-- Status badge with pulse animation -->
                <Border Grid.Column="2" CornerRadius="20" Padding="16,7"
                        VerticalAlignment="Center" BorderThickness="1"
                        Background="{Binding StatusColor, Converter={StaticResource HexToBrush}, ConverterParameter=15}"
                        BorderBrush="{Binding StatusColor, Converter={StaticResource HexToBrush}, ConverterParameter=40}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8"
                                 Margin="0,0,8,0"
                                 VerticalAlignment="Center"
                                 Fill="{Binding StatusColor, Converter={StaticResource HexToBrush}}">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="DotPulse">
                                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="1.0" To="0.15"
                                                                         Duration="0:0:0.5">
                                                            <DoubleAnimation.EasingFunction>
                                                                <SineEase EasingMode="EaseInOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                         From="1.0" To="1.5"
                                                                         Duration="0:0:0.5">
                                                            <DoubleAnimation.EasingFunction>
                                                                <SineEase EasingMode="EaseInOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                         From="1.0" To="1.5"
                                                                         Duration="0:0:0.5">
                                                            <DoubleAnimation.EasingFunction>
                                                                <SineEase EasingMode="EaseInOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="DotPulse"/>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding StatusLabel}"
                                   FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{Binding StatusColor, Converter={StaticResource HexToBrush}}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ══ MAIN CONTENT ═══════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="12,10,12,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="285"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="285"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT: SETTINGS PANEL ─────────────────────────────────────── -->
            <Border Grid.Column="0"
                    Background="{StaticResource CardGradient}"
                    CornerRadius="14" Margin="0,0,10,0" Padding="16"
                    BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" ShadowDepth="2" BlurRadius="16" Opacity="0.35"/>
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="SIMULATION SETTINGS"
                                   Style="{StaticResource HeadingSmall}" Margin="0,0,0,16"/>

                        <TextBlock Text="Queue Model" Style="{StaticResource HeadingMedium}" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="92"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Arrival Rate &#x3BB; (pax/min)"
                                       Style="{StaticResource ParamLabel}" TextWrapping="Wrap"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ArrivalRate, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ParamTextBox}"
                                     IsEnabled="{Binding CanEditParams}"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="92"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Service Rate &#x3BC; (pax/min)"
                                       Style="{StaticResource ParamLabel}" TextWrapping="Wrap"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ServiceRate, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ParamTextBox}"
                                     IsEnabled="{Binding CanEditParams}"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="92"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Duration (minutes)"
                                       Style="{StaticResource ParamLabel}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding DurationMinutes, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ParamTextBox}"
                                     IsEnabled="{Binding CanEditParams}"/>
                        </Grid>

                        <Border CornerRadius="7" Padding="10,7" Margin="0,4,0,14"
                                BorderThickness="1"
                                BorderBrush="{Binding KpiRho, Converter={StaticResource UtilToBrush}}"
                                Background="#06101E">
                            <TextBlock Text="{Binding StabilityHint}"
                                       FontFamily="Segoe UI" FontSize="11"
                                       Foreground="{Binding KpiRho, Converter={StaticResource UtilToBrush}}"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <Separator Style="{StaticResource HSep}"/>
                        <TextBlock Text="Flow Probabilities"
                                   Style="{StaticResource HeadingMedium}" Margin="0,6,0,10"/>

                        <Grid Margin="0,0,0,7">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="92"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Ticket Required" Style="{StaticResource ParamLabel}"/>
                            <TextBox Grid.Column="1" Text="{Binding TicketRequiredProb, StringFormat=F2, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ParamTextBox}" IsEnabled="{Binding CanEditParams}"/>
                        </Grid>
                        <Grid Margin="0,0,0,7">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="92"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Buy Ticket (Inquiry)" Style="{StaticResource ParamLabel}"/>
                            <TextBox Grid.Column="1" Text="{Binding BuyTicketProb, StringFormat=F2, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ParamTextBox}" IsEnabled="{Binding CanEditParams}"/>
                        </Grid>
                        <Grid Margin="0,0,0,7">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="92"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Use Card (vs Cash)" Style="{StaticResource ParamLabel}"/>
                            <TextBox Grid.Column="1" Text="{Binding CardUsageProb, StringFormat=F2, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ParamTextBox}" IsEnabled="{Binding CanEditParams}"/>
                        </Grid>
                        <Grid Margin="0,0,0,7">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="92"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Card Valid" Style="{StaticResource ParamLabel}"/>
                            <TextBox Grid.Column="1" Text="{Binding CardValidProb, StringFormat=F2, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ParamTextBox}" IsEnabled="{Binding CanEditParams}"/>
                        </Grid>
                        <Grid Margin="0,0,0,7">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="92"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Account Valid" Style="{StaticResource ParamLabel}"/>
                            <TextBox Grid.Column="1" Text="{Binding AccountValidProb, StringFormat=F2, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ParamTextBox}" IsEnabled="{Binding CanEditParams}"/>
                        </Grid>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="92"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Sufficient Funds" Style="{StaticResource ParamLabel}"/>
                            <TextBox Grid.Column="1" Text="{Binding SufficientFundsProb, StringFormat=F2, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ParamTextBox}" IsEnabled="{Binding CanEditParams}"/>
                        </Grid>

                        <CheckBox Style="{StaticResource ToggleCheck}"
                                  IsChecked="{Binding TraceModeEnabled}"
                                  Content="Show step trace (first 50)"
                                  Margin="0,0,0,12"
                                  IsEnabled="{Binding CanEditParams}"/>

                        <Border CornerRadius="7" Padding="10,7" Margin="0,0,0,10"
                                Background="#2D1010" BorderThickness="1" BorderBrush="#5A1B1B"
                                Visibility="{Binding HasValidationError, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding ValidationError}"
                                       FontFamily="Segoe UI" FontSize="11"
                                       Foreground="{StaticResource AccentRedBrush}"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <Separator Style="{StaticResource HSep}"/>
                        <TextBlock Text="CONTROLS" Style="{StaticResource HeadingSmall}" Margin="0,6,0,12"/>

                        <WrapPanel>
                            <Button Content="&#x25B6;  Simulate" Style="{StaticResource ButtonStart}"
                                    Command="{Binding StartCommand}" Margin="0,0,6,6"/>
                            <Button Content="&#x23F8;  Pause"   Style="{StaticResource ButtonPause}"
                                    Command="{Binding PauseCommand}" Margin="0,0,6,6"/>
                            <Button Content="&#x25B6;  Resume"  Style="{StaticResource ButtonResume}"
                                    Command="{Binding ResumeCommand}" Margin="0,0,6,6"/>
                            <Button Content="&#x23F9;  Stop"    Style="{StaticResource ButtonStop}"
                                    Command="{Binding StopCommand}" Margin="0,0,6,6"/>
                            <Button Content="&#x21BA;  Reset"   Style="{StaticResource ButtonReset}"
                                    Command="{Binding ResetCommand}" Margin="0,0,0,6"/>
                        </WrapPanel>

                        <Separator Style="{StaticResource HSep}"/>
                        <TextBlock Text="PLAYBACK SPEED" Style="{StaticResource HeadingSmall}" Margin="0,6,0,10"/>
                        <ComboBox ItemsSource="{Binding SpeedOptions}"
                                  SelectedItem="{Binding SelectedSpeed}"
                                  Style="{StaticResource SpeedComboBox}"
                                  HorizontalAlignment="Left"/>

                        <Separator Style="{StaticResource HSep}"/>
                        <TextBlock Text="STEP TRACE" Style="{StaticResource HeadingSmall}" Margin="0,6,0,8"/>
                        <Border Height="120" Background="#04080F" CornerRadius="7" Padding="8"
                                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                                Visibility="{Binding TraceModeEnabled, Converter={StaticResource BoolToVisibility}}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding PassengerLog}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontSize="9"
                                                       FontFamily="Consolas"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" Margin="0,1"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ── CENTER: FLOW DIAGRAM ──────────────────────────────────────── -->
            <Border Grid.Column="1"
                    Background="{StaticResource CardGradient}"
                    CornerRadius="14" Margin="0,0,10,0"
                    BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" ShadowDepth="2" BlurRadius="16" Opacity="0.35"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Progress / info bar -->
                    <Border Grid.Row="0" Padding="16,12"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="FLOW DIAGRAM"
                                           Style="{StaticResource HeadingSmall}" Margin="0,0,0,6"/>
                                <ProgressBar Value="{Binding PlaybackProgress}"
                                             Maximum="{Binding PlaybackTotal}"
                                             Style="{StaticResource SimProgressBar}"
                                             Width="280"
                                             HorizontalAlignment="Left"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        VerticalAlignment="Center" Margin="0,0,4,0">
                                <TextBlock Text="T=" Style="{StaticResource KpiLabel}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding SimCurrentTime, StringFormat=F1}"
                                           FontFamily="Segoe UI" FontSize="12" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBlueBrightBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="min" Style="{StaticResource KpiLabel}"
                                           VerticalAlignment="Center" Margin="2,0,14,0"/>

                                <Border CornerRadius="4" Padding="7,3" Margin="0,0,6,0"
                                        Background="#0A2215">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x2713; " FontSize="10"
                                                   Foreground="{StaticResource AccentGreenBrush}"/>
                                        <TextBlock Text="{Binding TotalCompleted}"
                                                   FontFamily="Segoe UI" FontSize="12" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentGreenBrush}"/>
                                    </StackPanel>
                                </Border>
                                <Border CornerRadius="4" Padding="7,3" Margin="0,0,6,0"
                                        Background="#0A1228">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x2191; " FontSize="10"
                                                   Foreground="{StaticResource AccentBlueBrush}"/>
                                        <TextBlock Text="{Binding TotalArrived}"
                                                   FontFamily="Segoe UI" FontSize="12" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBlueBrush}"/>
                                    </StackPanel>
                                </Border>
                                <Border CornerRadius="4" Padding="7,3"
                                        Background="#200A0A">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x2717; " FontSize="10"
                                                   Foreground="{StaticResource AccentRedBrush}"/>
                                        <TextBlock Text="{Binding TotalLeft}"
                                                   FontFamily="Segoe UI" FontSize="12" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentRedBrush}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Scrollable flow canvas -->
                    <ScrollViewer Grid.Row="1"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="Transparent">
                        <Canvas Width="1080" Height="1185" ClipToBounds="False">

                            <!-- ── EDGES ───────────────────────────────────── -->
                            <ItemsControl ItemsSource="{Binding FlowEdges}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas Width="1080" Height="1185"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Canvas Width="1" Height="1" ClipToBounds="False">
                                            <Polyline Points="{Binding Points}"
                                                      Stroke="#2D4F7A"
                                                      StrokeThickness="1.8"
                                                      StrokeLineJoin="Round"/>
                                            <Polygon Points="{Binding ArrowheadPoints}"
                                                     Fill="#2D4F7A" Stroke="#2D4F7A"
                                                     StrokeThickness="1"/>
                                            <TextBlock Canvas.Left="{Binding LabelLeft}"
                                                       Canvas.Top="{Binding LabelTop}"
                                                       Text="{Binding Label}"
                                                       Visibility="{Binding HasLabel, Converter={StaticResource BoolToVisibility}}"
                                                       FontFamily="Segoe UI" FontSize="9"
                                                       FontWeight="Bold"
                                                       Foreground="#60A5FA"
                                                       Background="#0A1525"
                                                       Padding="3,1"/>
                                        </Canvas>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- ── NODES ───────────────────────────────────── -->
                            <ItemsControl ItemsSource="{Binding FlowNodes}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas Width="1080" Height="1185"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                                        <Setter Property="Canvas.Top"  Value="{Binding Top}"/>
                                        <Setter Property="Width"       Value="{Binding Width}"/>
                                        <Setter Property="Height"      Value="{Binding Height}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Width="{Binding Width}" Height="{Binding Height}"
                                              ToolTip="{Binding Title}">
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Setter Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect Color="#3B82F6"
                                                                              ShadowDepth="0"
                                                                              BlurRadius="0"
                                                                              Opacity="0.85"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <DataTrigger.EnterActions>
                                                                <BeginStoryboard x:Name="NodeGlowIn">
                                                                    <Storyboard>
                                                                        <DoubleAnimation
                                                                            Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                                            To="18" Duration="0:0:0.3">
                                                                            <DoubleAnimation.EasingFunction>
                                                                                <CubicEase EasingMode="EaseOut"/>
                                                                            </DoubleAnimation.EasingFunction>
                                                                        </DoubleAnimation>
                                                                        <DoubleAnimation
                                                                            Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                                            From="14" To="24"
                                                                            Duration="0:0:0.7"
                                                                            AutoReverse="True"
                                                                            RepeatBehavior="Forever"
                                                                            BeginTime="0:0:0.3">
                                                                            <DoubleAnimation.EasingFunction>
                                                                                <SineEase EasingMode="EaseInOut"/>
                                                                            </DoubleAnimation.EasingFunction>
                                                                        </DoubleAnimation>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.EnterActions>
                                                            <DataTrigger.ExitActions>
                                                                <StopStoryboard BeginStoryboardName="NodeGlowIn"/>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation
                                                                            Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                                            To="0" Duration="0:0:0.4">
                                                                            <DoubleAnimation.EasingFunction>
                                                                                <CubicEase EasingMode="EaseOut"/>
                                                                            </DoubleAnimation.EasingFunction>
                                                                        </DoubleAnimation>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.ExitActions>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>

                                            <!-- Diamond for decision nodes -->
                                            <Polygon Points="{Binding DiamondPoints}"
                                                     Fill="{Binding CurrentBackground,   Converter={StaticResource HexToBrush}}"
                                                     Stroke="{Binding CurrentBorderColor, Converter={StaticResource HexToBrush}}"
                                                     StrokeThickness="1.5"
                                                     Visibility="{Binding IsDecision, Converter={StaticResource BoolToVisibility}}"/>

                                            <!-- Rectangle for non-decision nodes -->
                                            <Border Background="{Binding CurrentBackground,   Converter={StaticResource HexToBrush}}"
                                                    BorderBrush="{Binding CurrentBorderColor, Converter={StaticResource HexToBrush}}"
                                                    BorderThickness="1.5"
                                                    CornerRadius="{Binding CornerRadius}"
                                                    Visibility="{Binding IsNotDecision, Converter={StaticResource BoolToVisibility}}"/>

                                            <!-- Node title -->
                                            <TextBlock Text="{Binding Title}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontFamily="Segoe UI" FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="#E2E8F0"
                                                       TextWrapping="Wrap"
                                                       TextAlignment="Center"
                                                       Margin="6,2"
                                                       MaxWidth="{Binding Width}"/>

                                            <!-- Active passenger count badge with scale-in animation -->
                                            <Border Width="20" Height="20" CornerRadius="10"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Margin="0,-6,-6,0"
                                                    Background="#F59E0B"
                                                    Visibility="{Binding HasActivePassengers, Converter={StaticResource BoolToVisibility}}">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                                        <Setter Property="RenderTransform">
                                                            <Setter.Value>
                                                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasActivePassengers}" Value="True">
                                                                <DataTrigger.EnterActions>
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <DoubleAnimation
                                                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                                From="0" To="1" Duration="0:0:0.22">
                                                                                <DoubleAnimation.EasingFunction>
                                                                                    <BackEase EasingMode="EaseOut" Amplitude="0.4"/>
                                                                                </DoubleAnimation.EasingFunction>
                                                                            </DoubleAnimation>
                                                                            <DoubleAnimation
                                                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                                From="0" To="1" Duration="0:0:0.22">
                                                                                <DoubleAnimation.EasingFunction>
                                                                                    <BackEase EasingMode="EaseOut" Amplitude="0.4"/>
                                                                                </DoubleAnimation.EasingFunction>
                                                                            </DoubleAnimation>
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </DataTrigger.EnterActions>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Border.Effect>
                                                    <DropShadowEffect Color="#F59E0B"
                                                                      ShadowDepth="0"
                                                                      BlurRadius="6"
                                                                      Opacity="0.7"/>
                                                </Border.Effect>
                                                <TextBlock Text="{Binding ActiveCountLabel}"
                                                           FontSize="9" FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="White"/>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- ── PASSENGER TOKENS ─────────────────────────── -->
                            <ItemsControl ItemsSource="{Binding PassengerTokens}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas Width="1080" Height="1185"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                        <Setter Property="Canvas.Top"  Value="{Binding Y}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Width="18" Height="18" ToolTip="{Binding Label}">
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                                    <Setter Property="RenderTransform">
                                                        <Setter.Value>
                                                            <ScaleTransform ScaleX="0" ScaleY="0"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation
                                                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                        From="0" To="1" Duration="0:0:0.2">
                                                                        <DoubleAnimation.EasingFunction>
                                                                            <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                                                                        </DoubleAnimation.EasingFunction>
                                                                    </DoubleAnimation>
                                                                    <DoubleAnimation
                                                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                        From="0" To="1" Duration="0:0:0.2">
                                                                        <DoubleAnimation.EasingFunction>
                                                                            <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                                                                        </DoubleAnimation.EasingFunction>
                                                                    </DoubleAnimation>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>
                                            <Ellipse Fill="{Binding TokenColor, Converter={StaticResource HexToBrush}}"
                                                     Stroke="White" StrokeThickness="0.8"
                                                     Opacity="0.92"/>
                                            <TextBlock Text="{Binding Label}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontFamily="Segoe UI" FontSize="7"
                                                       FontWeight="Bold" Foreground="White"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </Canvas>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ── RIGHT: KPI PANEL ─────────────────────────────────────────── -->
            <Border Grid.Column="2"
                    Background="{StaticResource CardGradient}"
                    CornerRadius="14" Padding="16"
                    BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" ShadowDepth="2" BlurRadius="16" Opacity="0.35"/>
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="LIVE METRICS"
                                   Style="{StaticResource HeadingSmall}" Margin="0,0,0,14"/>

                        <!-- Served / Left / Arrived counters -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="9" Padding="8,10" Margin="0,0,4,0"
                                    Background="#0A2215" BorderThickness="1" BorderBrush="#143A20">
                                <StackPanel>
                                    <TextBlock Text="{Binding TotalCompleted}" Style="{StaticResource KpiValue}"
                                               FontSize="22" Foreground="{StaticResource AccentGreenBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Served" Style="{StaticResource KpiLabel}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" CornerRadius="9" Padding="8,10" Margin="2,0"
                                    Background="#1F0A0A" BorderThickness="1" BorderBrush="#3A1414">
                                <StackPanel>
                                    <TextBlock Text="{Binding TotalLeft}" Style="{StaticResource KpiValue}"
                                               FontSize="22" Foreground="{StaticResource AccentRedBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Left" Style="{StaticResource KpiLabel}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" CornerRadius="9" Padding="8,10" Margin="4,0,0,0"
                                    Background="#0A1428" BorderThickness="1" BorderBrush="#142240">
                                <StackPanel>
                                    <TextBlock Text="{Binding TotalArrived}" Style="{StaticResource KpiValue}"
                                               FontSize="22" Foreground="{StaticResource AccentBlueBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Arrived" Style="{StaticResource KpiLabel}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Separator Style="{StaticResource HSep}"/>
                        <TextBlock Text="M/M/1 ANALYTICAL KPIs"
                                   Style="{StaticResource HeadingSmall}" Margin="0,4,0,10"/>

                        <!-- KPI cards with hover highlight -->
                        <Border CornerRadius="9" Padding="12,10" Margin="0,0,0,6"
                                BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{StaticResource BackgroundElevatedBrush}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderHoverBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Utilisation (&#x3C1;)" Style="{StaticResource KpiLabel}"/>
                                    <TextBlock Text="&#x3BB; / &#x3BC;" FontFamily="Segoe UI" FontSize="9" Foreground="#334155"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding KpiRho, Converter={StaticResource DoubleToFixed}}"
                                           FontFamily="Segoe UI" FontSize="22" FontWeight="Bold"
                                           Foreground="{Binding KpiRho, Converter={StaticResource UtilToBrush}}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border CornerRadius="9" Padding="12,10" Margin="0,0,0,6"
                                BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{StaticResource BackgroundElevatedBrush}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderHoverBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Avg Queue Wait (Wq)" Style="{StaticResource KpiLabel}"/>
                                    <TextBlock Text="minutes" FontFamily="Segoe UI" FontSize="9" Foreground="#334155"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding KpiWq, Converter={StaticResource DoubleToFixed}}"
                                           FontFamily="Segoe UI" FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border CornerRadius="9" Padding="12,10" Margin="0,0,0,6"
                                BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{StaticResource BackgroundElevatedBrush}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderHoverBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Avg System Time (W)" Style="{StaticResource KpiLabel}"/>
                                    <TextBlock Text="minutes" FontFamily="Segoe UI" FontSize="9" Foreground="#334155"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding KpiW, Converter={StaticResource DoubleToFixed}}"
                                           FontFamily="Segoe UI" FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border CornerRadius="9" Padding="12,10" Margin="0,0,0,6"
                                BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{StaticResource BackgroundElevatedBrush}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderHoverBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Avg Queue Length (Lq)" Style="{StaticResource KpiLabel}"/>
                                    <TextBlock Text="passengers" FontFamily="Segoe UI" FontSize="9" Foreground="#334155"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding KpiLq, Converter={StaticResource DoubleToFixed}}"
                                           FontFamily="Segoe UI" FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border CornerRadius="9" Padding="12,10" Margin="0,0,0,12"
                                BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{StaticResource BackgroundElevatedBrush}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderHoverBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Avg in System (L)" Style="{StaticResource KpiLabel}"/>
                                    <TextBlock Text="passengers" FontFamily="Segoe UI" FontSize="9" Foreground="#334155"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding KpiL, Converter={StaticResource DoubleToFixed}}"
                                           FontFamily="Segoe UI" FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Separator Style="{StaticResource HSep}"/>
                        <TextBlock Text="SIMULATION RESULTS"
                                   Style="{StaticResource HeadingSmall}" Margin="0,4,0,10"/>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Avg Wait (simulated)" Style="{StaticResource KpiLabel}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding SimAvgWait, Converter={StaticResource DoubleToFixed}}"
                                       FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Avg System (simulated)" Style="{StaticResource KpiLabel}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding SimAvgSys, Converter={StaticResource DoubleToFixed}}"
                                       FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Throughput (pax/min)" Style="{StaticResource KpiLabel}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Throughput, Converter={StaticResource DoubleToFixed}}"
                                       FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentGreenBrush}"/>
                        </Grid>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Completion Rate" Style="{StaticResource KpiLabel}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding CompletionRate, StringFormat=F1}"
                                       FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentGreenBrush}"/>
                        </Grid>

                        <Separator Style="{StaticResource HSep}"/>
                        <Border CornerRadius="8" Padding="12,10" Margin="0,8,0,0"
                                Background="#04080F" BorderThickness="1"
                                BorderBrush="{StaticResource BorderBrush}">
                            <TextBlock Text="{Binding PlainSummary}"
                                       FontFamily="Segoe UI" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       LineHeight="17"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ══ STATUS BAR ═════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{StaticResource TitleBarGradient}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding PlainSummary}"
                           Style="{StaticResource KpiLabel}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Opacity="0.7"/>
                <TextBlock Grid.Column="1"
                           Text="Karachi Railway System v2.1  ·  M/M/1 Flow Diagram"
                           Style="{StaticResource KpiLabel}"
                           VerticalAlignment="Center"
                           Opacity="0.5"/>
            </Grid>
        </Border>
    </Grid>
</Window>
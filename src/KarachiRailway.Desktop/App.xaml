<Application x:Class="KarachiRailway.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:KarachiRailway.Desktop"
             xmlns:conv="clr-namespace:KarachiRailway.Desktop.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Converters -->
        <conv:BoolToVisibilityConverter         x:Key="BoolToVisibility"/>
        <conv:InverseBoolToVisibilityConverter  x:Key="InverseBoolToVisibility"/>
        <conv:InverseBoolConverter              x:Key="InverseBool"/>
        <conv:DoubleToPercentConverter          x:Key="DoubleToPercent"/>
        <conv:DoubleToFixedStringConverter      x:Key="DoubleToFixed"/>
        <conv:HexColorToBrushConverter          x:Key="HexToBrush"/>
        <conv:UtilizationToBrushConverter       x:Key="UtilToBrush"/>

        <!-- Color Palette -->
        <Color x:Key="BackgroundDeep">#0F172A</Color>
        <Color x:Key="BackgroundCard">#1E293B</Color>
        <Color x:Key="BackgroundPanel">#162032</Color>
        <Color x:Key="AccentBlue">#3B82F6</Color>
        <Color x:Key="AccentGreen">#22C55E</Color>
        <Color x:Key="AccentAmber">#F59E0B</Color>
        <Color x:Key="AccentRed">#EF4444</Color>
        <Color x:Key="TextPrimary">#F1F5F9</Color>
        <Color x:Key="TextSecondary">#94A3B8</Color>
        <Color x:Key="Border">#334155</Color>

        <SolidColorBrush x:Key="BackgroundDeepBrush"  Color="{StaticResource BackgroundDeep}"/>
        <SolidColorBrush x:Key="BackgroundCardBrush"  Color="{StaticResource BackgroundCard}"/>
        <SolidColorBrush x:Key="BackgroundPanelBrush" Color="{StaticResource BackgroundPanel}"/>
        <SolidColorBrush x:Key="AccentBlueBrush"      Color="{StaticResource AccentBlue}"/>
        <SolidColorBrush x:Key="AccentGreenBrush"     Color="{StaticResource AccentGreen}"/>
        <SolidColorBrush x:Key="AccentAmberBrush"     Color="{StaticResource AccentAmber}"/>
        <SolidColorBrush x:Key="AccentRedBrush"       Color="{StaticResource AccentRed}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush"     Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush"   Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="BorderBrush"          Color="{StaticResource Border}"/>

        <!-- Typography -->
        <Style x:Key="HeadingLarge" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>
        <Style x:Key="HeadingMedium" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>
        <Style x:Key="HeadingSmall" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        </Style>
        <Style x:Key="BodyText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="KpiValue" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>
        <Style x:Key="KpiLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        </Style>

        <!-- TextBox Style -->
        <Style x:Key="ParamTextBox" TargetType="TextBox">
            <Setter Property="Background"   Value="#0F172A"/>
            <Setter Property="Foreground"   Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush"  Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="8,6"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontFamily"   Value="Segoe UI"/>
            <Setter Property="MinWidth"     Value="90"/>
            <Setter Property="CaretBrush"   Value="{StaticResource TextPrimaryBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Label Style -->
        <Style x:Key="ParamLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Button Base -->
        <Style x:Key="ButtonBase" TargetType="Button">
            <Setter Property="FontFamily"   Value="Segoe UI"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"      Value="20,10"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.70"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ButtonStart" TargetType="Button" BasedOn="{StaticResource ButtonBase}">
            <Setter Property="Background" Value="{StaticResource AccentGreenBrush}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="ButtonPause" TargetType="Button" BasedOn="{StaticResource ButtonBase}">
            <Setter Property="Background" Value="{StaticResource AccentAmberBrush}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="ButtonResume" TargetType="Button" BasedOn="{StaticResource ButtonBase}">
            <Setter Property="Background" Value="{StaticResource AccentBlueBrush}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="ButtonStop" TargetType="Button" BasedOn="{StaticResource ButtonBase}">
            <Setter Property="Background" Value="{StaticResource AccentRedBrush}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="ButtonReset" TargetType="Button" BasedOn="{StaticResource ButtonBase}">
            <Setter Property="Background" Value="{StaticResource BackgroundPanelBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        </Style>

        <!-- Speed ComboBox style -->
        <Style x:Key="SpeedComboBox" TargetType="ComboBox">
            <Setter Property="Background"        Value="#0F172A"/>
            <Setter Property="Foreground"        Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush"       Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="Padding"           Value="8,6"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="FontFamily"        Value="Segoe UI"/>
            <Setter Property="MinWidth"          Value="70"/>
        </Style>

        <!-- CheckBox Style -->
        <Style x:Key="ToggleCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="13"/>
        </Style>

        <!-- Separator style -->
        <Style x:Key="HSep" TargetType="Separator">
            <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Margin"     Value="0,8"/>
        </Style>
    </Application.Resources>
</Application>

